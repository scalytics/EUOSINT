      "requires_any": ["flood", "storm", "blaze", "quake", "fire", "crash", "surge"],
      "with_any": ["appoints", "names", "hires", "ceo", "cto", "cfo", "product", "startup", "fintech", "partnership", "revenue", "funding", "series"],
      "effect": "drop"
    },
    {
      "name": "metaphorical-disaster-language",
      "requires_any": ["tsunami", "flood", "avalanche", "earthquake", "storm", "firestorm", "meltdown", "explosion"],
