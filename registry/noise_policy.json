{
  "version": "v1.0.0",
  "hard_block_terms": [
    "casino bonus",
    "sports betting",
    "giveaway",
    "lottery",
    "sweepstakes",
    "celebrity gossip",
    "viral prank",
    "game show"
  ],
  "downgrade_terms": [
    "press conference",
    "awareness campaign",
    "workshop",
    "partnership agreement",
    "annual report",
    "weekly summary",
    "monthly review"
  ],
  "actionable_overrides": [
    "wanted",
    "missing person",
    "public appeal",
    "sexual assault",
    "sex trafficking",
    "sextortion",
    "homicide",
    "kidnapping",
    "terror",
    "explosion",
    "evacuation",
    "interpol",
    "cve-"
  ],
  "cooccurrence_rules": [
    {
      "name": "sexual-crime-intelligence",
      "requires_any": ["sex", "sexual"],
      "with_any": ["assault", "police", "investigation", "suspect", "witness", "wanted", "missing"],
      "effect": "keep"
    },
    {
      "name": "incident-verification-context",
      "requires_any": ["explosion", "attack", "shooting", "abduction"],
      "with_any": ["police", "authority", "alert", "warning", "evacuation", "response"],
      "effect": "keep"
    }
  ]
}
