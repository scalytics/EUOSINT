# Minimal runtime configuration.
# Everything else runs on code defaults (see docs/advanced-config.md).

# Live URL (":80" keeps localhost mode).
KAFSIEM_SITE_ADDRESS=:80

# Parallel collector role.
# all|merge|fast|browser|api|api-ucdp|api-acled|api-gdelt
COLLECTOR_ROLE=all

# Internal API auth (auto-rotated on deploy — do not edit).
API_BEARER_TOKEN=

# External conflict data APIs.
UCDP_ACCESS_TOKEN=
ACLED_USERNAME=
ACLED_PASSWORD=

# Source-vetting LLM (optional).
SOURCE_VETTING_ENABLED=false
SOURCE_VETTING_API_KEY=
SOURCE_VETTING_MODEL=grok-4-1-fast

# Alert translation/classification LLM (optional, higher token usage).
ALERT_LLM_ENABLED=false
ALERT_LLM_MODEL=grok-4-1-fast

# Kafka alerts ingestion (optional).
KAFKA_ENABLED=false
KAFKA_BROKERS=
KAFKA_TOPICS=
KAFKA_GROUP_ID=kafsiem-kafka
KAFKA_CLIENT_ID=kafsiem-collector
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_TLS_INSECURE_SKIP_VERIFY=false
KAFKA_TEST_ON_START=true
KAFKA_MAX_RECORD_BYTES=1048576
KAFKA_MAX_PER_CYCLE=500
KAFKA_POLL_TIMEOUT_MS=2000
KAFKA_MAPPER_PATH=registry/kafka_mapper.json

# AgentOps Kafka tracking (optional).
AGENTOPS_ENABLED=false
AGENTOPS_BROKERS=
AGENTOPS_GROUP_NAME=
AGENTOPS_GROUP_ID=kafsiem-agentops
AGENTOPS_CLIENT_ID=kafsiem-agentops
AGENTOPS_TOPIC_MODE=auto
AGENTOPS_TOPICS=
AGENTOPS_SECURITY_PROTOCOL=PLAINTEXT
AGENTOPS_SASL_MECHANISM=PLAIN
AGENTOPS_USERNAME=
AGENTOPS_PASSWORD=
AGENTOPS_TLS_INSECURE_SKIP_VERIFY=false
AGENTOPS_POLICY_PATH=/config/agentops_policy.yaml
AGENTOPS_REPLAY_ENABLED=true
AGENTOPS_REPLAY_PREFIX=kafsiem-agentops-replay
AGENTOPS_OUTPUT_PATH=public/agentops.db

# UI operating mode.
UI_MODE=OSINT
PROFILE=osint-default
UI_POLICY_PATH=/config/ui_policy.yaml
