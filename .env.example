EUOSINT_SITE_ADDRESS=:80
EUOSINT_HTTP_PORT=8080
EUOSINT_HTTPS_PORT=8443
EUOSINT_WEB_IMAGE=ghcr.io/scalytics/euosint-web:latest
EUOSINT_COLLECTOR_IMAGE=ghcr.io/scalytics/euosint-collector:latest
HTTP_TIMEOUT_MS=60000
BROWSER_ENABLED=true
BROWSER_TIMEOUT_MS=60000

# Collector retention + lifecycle tuning.
REMOVED_RETENTION_DAYS=14
ALERT_COOLDOWN_HOURS=24
ALERT_STALE_DAYS=14
ALERT_ARCHIVE_DAYS=90

# Stream fetch window and HTML scrape cadence.
RECENT_WINDOW_PER_SOURCE=20
HTML_SCRAPE_INTERVAL_HOURS=24
NOISE_POLICY_PATH=registry/noise_policy.json
NOISE_POLICY_B_PATH=registry/noise_policy_b.json
NOISE_POLICY_B_PERCENT=0
NOISE_METRICS_OUTPUT_PATH=public/noise-metrics.json

# Candidate crawler intake and dead-letter queue.
CANDIDATE_QUEUE_PATH=registry/source_candidates.json
SOVEREIGN_SEED_PATH=registry/sovereign_official_statements.seed.json
REPLACEMENT_QUEUE_PATH=registry/source_dead_letter.json
SEARCH_DISCOVERY_ENABLED=false
SEARCH_DISCOVERY_MAX_TARGETS=40
SEARCH_DISCOVERY_MAX_URLS_PER_TARGET=3
DDG_SEARCH_ENABLED=true
DDG_SEARCH_MAX_QUERIES=40
DDG_SEARCH_DELAY_MS=5000
STRUCTURED_DISCOVERY_INTERVAL_HOURS=168

# Source vetting agent.
SOURCE_VETTING_ENABLED=false
SOURCE_VETTING_REQUIRED=true
SOURCE_MIN_QUALITY=0.6
SOURCE_MIN_OPERATIONAL_RELEVANCE=0.6
OFFICIAL_STATEMENTS_MIN_QUALITY=0.75
OFFICIAL_STATEMENTS_MIN_OPERATIONAL_RELEVANCE=0.7
SOURCE_VETTING_PROVIDER=xai
SOURCE_VETTING_BASE_URL=https://api.x.ai/v1
SOURCE_VETTING_API_KEY=
SOURCE_VETTING_MODEL=grok-4-1-fast
SOURCE_VETTING_TEMPERATURE=0
SOURCE_VETTING_MAX_SAMPLE_ITEMS=6

# Alarm lane classification threshold.
ALARM_RELEVANCE_THRESHOLD=0.72

# Alert-level LLM gate: yes/no + English translation + category id.
ALERT_LLM_ENABLED=false
ALERT_LLM_MODEL=grok-4-1-fast
ALERT_LLM_MAX_ITEMS_PER_SOURCE=4

# ACLED conflict event data — battles, explosions, protests, military movements.
# 1. Register at https://acleddata.com/register/
#    IMPORTANT: Use an institutional email (@yourorg.com) — gmail/public email
#    only grants "Open myACLED" (web export), not API access.
# 2. Once registered, your institutional account should have API access.
#    If not, contact access@acleddata.com to request API tier.
# 3. Auth: OAuth2 password grant → Bearer token → GET /api/acled/read
ACLED_USERNAME=
ACLED_PASSWORD=
UCDP_ACCESS_TOKEN=

# Static map layer: military bases/installations (GeoJSON refresh cadence).
MILITARY_BASES_ENABLED=true
MILITARY_BASES_URL=https://services2.arcgis.com/C8EMgrsFcRFL6LrL/ArcGIS/rest/services/GOM_National_Security/FeatureServer/7/query?where=1%3D1&outFields=*&f=geojson
MILITARY_BASES_OUTPUT_PATH=public/geo/military-bases.geojson
MILITARY_BASES_REFRESH_HOURS=168
