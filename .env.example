# Minimal runtime configuration.
# Everything else runs on code defaults (see docs/advanced-config.md).

# Live URL (":80" keeps localhost mode).
EUOSINT_SITE_ADDRESS=:80

# Parallel collector role.
# all|merge|fast|browser|api|api-ucdp|api-acled|api-gdelt
COLLECTOR_ROLE=all

# External conflict data APIs.
UCDP_ACCESS_TOKEN=
ACLED_USERNAME=
ACLED_PASSWORD=

# Source-vetting LLM (optional).
SOURCE_VETTING_ENABLED=false
SOURCE_VETTING_API_KEY=
SOURCE_VETTING_MODEL=grok-4-1-fast

# Alert translation/classification LLM (optional, higher token usage).
ALERT_LLM_ENABLED=false
ALERT_LLM_MODEL=grok-4-1-fast
